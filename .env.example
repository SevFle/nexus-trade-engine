# ── Nexus Trade Engine — Environment Variables ──
# Copy to .env and customize:  cp .env.example .env
#
# The single source of truth for NEXUS_* settings is engine/config.py
# (field `foo_bar` ↔ env `NEXUS_FOO_BAR`). This file mirrors that set so
# operators see every knob without reading the source. Variables marked
# (REQUIRED) must be set before the engine boots in production.

# ── Postgres (consumed by docker-compose.yml; required for compose) ──
# Generate a password: openssl rand -hex 24
POSTGRES_USER=nexus
POSTGRES_PASSWORD=
POSTGRES_DB=nexus

# ── App ──
NEXUS_APP_ENV=development          # production | development | test
NEXUS_APP_DEBUG=false
NEXUS_APP_HOST=0.0.0.0
NEXUS_APP_PORT=8000
# JSON array literal: ["https://app.example.com"]
NEXUS_CORS_ORIGINS=["http://localhost:3000"]

# ── Database ──
# Compose assembles this from POSTGRES_* above; set it explicitly for
# non-compose runs.
NEXUS_DATABASE_URL=postgresql+asyncpg://nexus:CHANGE_ME@localhost:5432/nexus
NEXUS_DATABASE_POOL_SIZE=5
NEXUS_DATABASE_MAX_OVERFLOW=10

# ── Valkey / Redis (TaskIQ broker + cache + rate-limit backend) ──
NEXUS_VALKEY_URL=valkey://localhost:6379/0

# ── Observability ──
NEXUS_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
NEXUS_LOG_FORMAT=console          # console | json
NEXUS_LOG_SINK=stdout             # stdout | file | otlp
NEXUS_LOG_FILE_PATH=logs/engine.log
NEXUS_LOG_SAMPLING_INFO=1.0
NEXUS_LOG_SAMPLING_DEBUG=0.01
NEXUS_OTLP_ENDPOINT=              # OTLP traces+metrics exporter URL
NEXUS_SENTRY_DSN=
NEXUS_SENTRY_TRACES_SAMPLE_RATE=0.0
NEXUS_APP_VERSION=0.1.0

# ── Worker ──
NEXUS_WORKER_CONCURRENCY=4

# ── Rate limiting (per IP unless noted) ──
NEXUS_RATE_LIMIT_PER_MINUTE=600
NEXUS_RATE_LIMIT_BURST=60
NEXUS_RATE_LIMIT_EXEMPT_PATHS=/health,/metrics
# When true, limits are enforced globally via Valkey instead of per-pod.
NEXUS_RATE_LIMIT_VALKEY_ENABLED=false
NEXUS_RATE_LIMIT_VALKEY_KEY_TTL_SEC=3600
# JSON: {"viewer":[120,30],"admin":[6000,200]} (unknown roles fall back)
NEXUS_RATE_LIMIT_ROLE_TIERS=

# ── Data providers ──
# Path to a provider-registration YAML (see config/data_providers.example.yaml)
NEXUS_DATA_PROVIDERS_CONFIG=
NEXUS_DATA_PROVIDERS_DEFAULT=yahoo

# ── Legal / operator (substituted into rendered legal docs) ──
NEXUS_LEGAL_DOCUMENTS_DIR=legal
NEXUS_OPERATOR_NAME=Nexus Trade Engine
NEXUS_OPERATOR_EMAIL=legal@example.com
NEXUS_OPERATOR_URL=https://example.com
NEXUS_JURISDICTION=United States
NEXUS_PLATFORM_FEE_PERCENT=30

# ── Auth (REQUIRED in prod — generate: openssl rand -hex 32) ──
NEXUS_SECRET_KEY=
# Previous key, kept during a rotation window (dual-key verification).
NEXUS_SECRET_KEY_PREVIOUS=
NEXUS_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
NEXUS_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# CSV subset of: local,google,github,oidc,ldap
NEXUS_AUTH_PROVIDERS=local
NEXUS_AUTH_LOCAL_ALLOW_REGISTRATION=true

# ── MFA (Fernet key — openssl? use: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())")
NEXUS_MFA_ENCRYPTION_KEY=         # empty disables MFA enrollment
NEXUS_MFA_CHALLENGE_TTL_SECONDS=300
NEXUS_MFA_BACKUP_CODES_COUNT=10

# ── Google OAuth2 (enable by adding 'google' to NEXUS_AUTH_PROVIDERS) ──
NEXUS_GOOGLE_CLIENT_ID=
NEXUS_GOOGLE_CLIENT_SECRET=
NEXUS_GOOGLE_REDIRECT_URI=

# ── GitHub OAuth2 ──
NEXUS_GITHUB_CLIENT_ID=
NEXUS_GITHUB_CLIENT_SECRET=
NEXUS_GITHUB_REDIRECT_URI=

# ── OIDC ──
NEXUS_OIDC_DISCOVERY_URL=
NEXUS_OIDC_CLIENT_ID=
NEXUS_OIDC_CLIENT_SECRET=
NEXUS_OIDC_REDIRECT_URI=
NEXUS_OIDC_ROLE_CLAIM=roles

# ── LDAP ──
NEXUS_LDAP_SERVER_URL=
NEXUS_LDAP_BIND_DN=
NEXUS_LDAP_BIND_PASSWORD=
NEXUS_LDAP_SEARCH_BASE=
NEXUS_LDAP_ROLE_MAPPING={}

# ── WebSocket ──
NEXUS_WS_MAX_CONNECTIONS=5000
NEXUS_WS_AUTH_TIMEOUT_SECONDS=5.0
NEXUS_WS_HEARTBEAT_INTERVAL_SECONDS=30.0
NEXUS_WS_IDLE_TIMEOUT_SECONDS=300.0
NEXUS_WS_SEND_QUEUE_SIZE=256
NEXUS_WS_MAX_SUBSCRIPTIONS_PER_CONNECTION=50
NEXUS_WS_EVENT_BRIDGE_CONCURRENCY=32
NEXUS_WS_AUTH_RATE_LIMIT_PER_MINUTE=10

# ── MCP server (engine/mcp) ───────────────────────────────────────
# NOTE: these tune the MCP surface for LLM agents. The module ships every
# component (tools, resources, auth, rate limiting) but the runnable
# transport entry point `engine/mcp/server.py` is NOT on disk yet, so the
# server cannot be started today. See docs/mcp-server.md and the P1 entry
# in docs/known-limitations.md. Values below describe the contract the
# implemented components already enforce.
# Transport: stdio (default, subprocess + JSON-RPC on stdin/stdout) or http.
NEXUS_MCP_SERVER_NAME=nexus-mcp-server
NEXUS_MCP_SERVER_VERSION=0.1.0
NEXUS_MCP_TRANSPORT=stdio
NEXUS_MCP_HTTP_HOST=127.0.0.1
NEXUS_MCP_HTTP_PORT=8765
NEXUS_MCP_HTTP_PATH=/mcp
NEXUS_MCP_HTTP_LOG_LEVEL=info
# Auth / RBAC. When AUTH_REQUIRED=false an anonymous principal with
# DEFAULT_ROLE is issued (local-dev fast path). STATIC_API_KEYS is a JSON
# map {"<token>": "<role>"} for DB-free service-to-service auth.
NEXUS_MCP_AUTH_REQUIRED=true
NEXUS_MCP_DEFAULT_ROLE=viewer
NEXUS_MCP_TOKEN=
NEXUS_MCP_STATIC_API_KEYS=
# Per-principal token-bucket rate limiting (in-memory, per-process).
NEXUS_MCP_RATE_LIMIT_PER_MINUTE=120
NEXUS_MCP_RATE_LIMIT_BURST=30
# Result safety: keep tool responses inside an assistant's context budget.
NEXUS_MCP_RESULT_TOKEN_BUDGET=24000
NEXUS_MCP_DEFAULT_PAGE_SIZE=50
NEXUS_MCP_MAX_PAGE_SIZE=500
# Backtest execution knobs.
NEXUS_MCP_BACKTEST_PROGRESS_INTERVAL=0
NEXUS_MCP_BACKTEST_MAX_BARS=50000
NEXUS_MCP_BACKTEST_DEFAULT_PROVIDER=yahoo
