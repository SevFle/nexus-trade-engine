# ── Nexus Trade Engine — Environment Variables ──
# Copy to .env and customize for your setup.

# App
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_password@localhost:5432/nexus_trade

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Trading
DEFAULT_EXECUTION_MODE=paper
MAX_OPEN_POSITIONS=50
CIRCUIT_BREAKER_DRAWDOWN_PCT=0.10

# Cost Model
DEFAULT_COMMISSION_PER_TRADE=0.0
DEFAULT_SPREAD_BPS=5.0
DEFAULT_SLIPPAGE_BPS=10.0
SHORT_TERM_TAX_RATE=0.37
LONG_TERM_TAX_RATE=0.20

# Market Data
MARKET_DATA_PROVIDER=yahoo

# Plugin System
PLUGIN_DIR=./strategies
PLUGIN_SANDBOX_ENABLED=true
