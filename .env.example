# ── Nexus Trade Engine — Environment Variables ──
# Copy to .env and customize for your setup.

# App
NEXUS_APP_ENV=development
NEXUS_LOG_LEVEL=DEBUG

# Database
NEXUS_DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_password@localhost:5432/nexus_trade

# Valkey
NEXUS_VALKEY_URL=valkey://localhost:6379/0

# Auth (required — generate with: openssl rand -hex 32)
NEXUS_SECRET_KEY=

# Trading
NEXUS_DEFAULT_EXECUTION_MODE=paper
NEXUS_MAX_OPEN_POSITIONS=50
NEXUS_CIRCUIT_BREAKER_DRAWDOWN_PCT=0.10

# Cost Model
NEXUS_DEFAULT_COMMISSION_PER_TRADE=0.0
NEXUS_DEFAULT_SPREAD_BPS=5.0
NEXUS_DEFAULT_SLIPPAGE_BPS=10.0
NEXUS_SHORT_TERM_TAX_RATE=0.37
NEXUS_LONG_TERM_TAX_RATE=0.20

# Market Data
NEXUS_MARKET_DATA_PROVIDER=yahoo

# Plugin System
NEXUS_PLUGIN_DIR=./strategies
NEXUS_PLUGIN_SANDBOX_ENABLED=true
